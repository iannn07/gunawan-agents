# Gunawan AI Company — Environment Variables
# Copy this file to .env and fill in your values before starting the bridge.

# Claude API key — get from console.anthropic.com
ANTHROPIC_API_KEY=your-anthropic-api-key-here

# Telegram bot token — get from @BotFather on Telegram
# Steps: /newbot → name it "Santoso" → copy the token
TELEGRAM_BOT_TOKEN=your-telegram-bot-token-here

# Telegram group chat ID — the ID of your "Gunawan HQ" group
# To find it: add @userinfobot to the group, it will reply with the chat ID
TELEGRAM_CHAT_ID=your-telegram-chat-id-here

# Paperclip API URL — default is localhost:3100 (run: npx paperclipai start)
PAPERCLIP_API_URL=http://localhost:3100

# Public HTTPS URL for this server (used to register the Telegram webhook)
# Use ngrok for demos: ngrok http 3200
# Use your domain for permanent setup: https://your-domain.com
WEBHOOK_URL=https://your-ngrok-or-domain-url-here
