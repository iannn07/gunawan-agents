{
  "permissions": {
    "allow": [
      "Bash(mkdir:*)",
      "Bash(git:*)",
      "Bash(npm install:*)",
      "Bash(npm uninstall:*)",
      "Bash(npm run:*)",
      "Bash(chmod +x .claude/hooks/*.sh)",
      "Bash(cp -r .claude/commands .gunawan/.claude/commands)",
      "Bash(cp -r .claude/agents .gunawan/.claude/agents)",
      "Bash(cp -r .claude/hooks .gunawan/.claude/hooks)",
      "Bash(cp -r .claude/skills .gunawan/.claude/skills)",
      "Bash(cp -r foundation .gunawan/foundation)",
      "Bash(cp -r architecture-os .gunawan/architecture-os)",
      "Bash(cp -r design-os .gunawan/design-os)",
      "Bash(cp -r implementation-os .gunawan/implementation-os)",
      "Bash(cp -r data-fetching-os .gunawan/data-fetching-os)",
      "Bash(cp -r deployment-os .gunawan/deployment-os)",
      "Bash(cp -r qa-os .gunawan/qa-os)",
      "Bash(cp standards-index.yml .gunawan/standards-index.yml)",
      "Bash(mkdir -p .gunawan/.claude)",
      "Bash(cp -r foundation           .gunawan/foundation)",
      "Bash(cp -r architecture-os      .gunawan/architecture-os)",
      "Bash(cp -r design-os            .gunawan/design-os)",
      "Bash(cp -r data-fetching-os     .gunawan/data-fetching-os)",
      "Bash([ -d docs ])",
      "Bash(cp -r docs  .gunawan/docs)",
      "Bash([ -d specs ])",
      "Bash(cp -r specs .gunawan/specs)",
      "Bash([ -f CHANGELOG.md ])"
    ]
  }
}
